# ============================================================================
# SIBO ERP — Plantilla de variables de entorno
# ============================================================================
# COPIA este archivo a ".env" y rellena los valores reales:
#     cp .env.example .env
# El archivo ".env" NO se sube a git (contiene secretos). Este .example SÍ.
# ----------------------------------------------------------------------------

# --- Django ---
# Clave secreta de Django. En producción usar una cadena larga y aleatoria.
# Generar una: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambiame-por-una-clave-larga-y-aleatoria

# DEBUG=True solo en desarrollo. En producción SIEMPRE False.
DEBUG=True

# Hosts permitidos (separados por coma). Incluye localhost y el comodín de
# subdominios .localhost para el desarrollo multitenant local.
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# --- PostgreSQL ---
# HOST debe ser "db" (nombre del servicio en docker-compose), no localhost,
# porque la conexión es entre contenedores.
POSTGRES_DB=sibo_erp
POSTGRES_USER=sibo
POSTGRES_PASSWORD=cambiame-password-postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
# "redis" es el nombre del servicio en docker-compose.
REDIS_URL=redis://redis:6379/0

# --- MinIO (almacenamiento de objetos S3-compatible) ---
# Credenciales raíz del servidor MinIO (las usa el contenedor minio al arrancar).
MINIO_ROOT_USER=sibo-minio-admin
MINIO_ROOT_PASSWORD=cambiame-password-minio
# Endpoint interno que usará Django para hablar con MinIO (nombre de servicio:puerto).
MINIO_ENDPOINT=minio:9000
# Bucket por defecto donde se guardan los archivos (prefijo por tenant a futuro).
MINIO_BUCKET_NAME=sibo-media
# Usar conexión segura (TLS). En local: False.
MINIO_USE_HTTPS=False
